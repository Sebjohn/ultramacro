rules_version = '2';

// Règles Firestore pour Ultra Macro.
// L'app stocke les données sous : workspaces/{workspaceId}/{poles|chantiers}/{id}

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Mode par défaut : espace de travail partagé, sans authentification ---
    // ⚠️ Cette règle autorise l'accès à quiconque connaît l'ID du projet Firebase.
    //    Convient à un outil interne SI vous activez App Check
    //    (console Firebase → App Check), qui bloque les clients hors application
    //    sans imposer de connexion utilisateur.
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if true;
    }

    // --- Alternative recommandée : exiger une authentification ---
    // Remplacez le bloc ci-dessus par celui-ci après avoir ajouté Firebase Auth :
    //
    // match /workspaces/{workspaceId}/{document=**} {
    //   allow read, write: if request.auth != null;
    // }

    // Tout le reste est refusé.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
